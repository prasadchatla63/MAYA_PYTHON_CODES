def is_palindrome(num):
    return str(num) == str(num)[::-1]

def is_prime(num):
    if num < 2:
        return False
    for i in range(2, int(num**0.5) + 1):
        if num % i == 0:
            return False
    return True

n = int(input())

num = n + 1

while True:
    if is_palindrome(num) and is_prime(num):
        print(num)
        break
    num += 1
