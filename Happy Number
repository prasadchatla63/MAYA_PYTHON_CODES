def sum_of_squares(num):
    s = 0
    while num > 0:
        digit = num % 10
        s += digit * digit
        num //= 10
    return s

n = int(input())

seen = set()

while n not in seen:
    if n == 1 or n == 7:
        print("True")
        break
    
    seen.add(n)
    n = sum_of_squares(n)
else:
    print("False"
