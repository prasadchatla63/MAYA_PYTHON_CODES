# Input
N = int(input())

# Handle special case for 0
if N == 0:
    print("DEFICIENT")
else:
    # Calculate sum of proper divisors
    sum_div = 0
    for i in range(1, N // 2 + 1):
        if N % i == 0:
            sum_div += i

    # Determine the type
    if sum_div == N:
        print("PERFECT")
    elif sum_div < N:
        print("DEFICIENT")
    else:
        print("ABUNDANT")
