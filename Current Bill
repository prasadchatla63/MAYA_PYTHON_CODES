# Take input for units consumed
units = int(input().strip())

# Calculate basic bill based on unit slabs
if units < 200:
    bill = units * 1.20
elif units < 400:
    bill = units * 1.50
elif units < 600:
    bill = units * 1.80
else:
    bill = units * 2.00

# Apply surcharge
if bill > 400:
    bill += bill * 0.15  # 15% surcharge
else:
    bill += 100  # minimum surcharge

# Print final bill rounded to 2 decimal places
print(f"{bill:.2f}")
