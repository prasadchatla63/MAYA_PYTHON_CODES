def is_prime(num):
    if num < 2:
        return False
    for i in range(2, int(num**0.5) + 1):
        if num % i == 0:
            return False
    return True

n1 = int(input())
n2 = int(input())

total = n1 + n2
x = 1

while True:
    if is_prime(total + x):
        print(x)
        break
    x += 1
