n = int(input())
nums = list(map(int, input().split()))

freq = {}
good = 0

for i in range(n):
    key = nums[i] - i
    if key in freq:
        good += freq[key]
        freq[key] += 1
    else:
        freq[key] = 1

total_pairs = n * (n - 1) // 2
bad_pairs = total_pairs - good

print(bad_pairs)
