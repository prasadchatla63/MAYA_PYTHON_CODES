def is_prime(num):
    if num < 2:
        return False
    for i in range(2, int(num**0.5) + 1):
        if num % i == 0:
            return False
    return True

n = int(input())

# Step 1: Check if number is prime
if not is_prime(n):
    print("Not Mega Prime")
else:
    # Step 2: Check digits
    valid = True
    for digit in str(n):
        if int(digit) not in [2, 3, 5, 7]:
            valid = False
            break

    if valid:
        print("Mega Prime")
    else:
        print("Not Mega Prime")
